@model BuzzIt.Requests.UpdatePostRequest

@{
    ViewData["Title"] = "Edit Post";
}

<div class="form-container animate-fade-in">
    <h1 class="d-flex flex-wrap align-items-center gap-2">
        <i class="bi bi-pencil-square text-primary" aria-hidden="true"></i>
        <span>Edit Post</span>
    </h1>

    <form asp-controller="Post" asp-action="Edit" method="post" class="needs-validation" novalidate>
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div class="mb-4">
            <label asp-for="Title" class="form-label">
                <i class="bi bi-type"></i> Title
            </label>
            <input asp-for="Title" class="form-control" placeholder="Enter an engaging title..." autocomplete="off" />
            <span asp-validation-for="Title" class="text-danger small d-block mt-1"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Content" class="form-label">
                <i class="bi bi-chat-text"></i> Content
            </label>
            <textarea asp-for="Content" class="form-control" rows="6" placeholder="Share your thoughts with the world..."></textarea>
            <span asp-validation-for="Content" class="text-danger small d-block mt-1"></span>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6 col-lg-4">
                <label asp-for="Category" class="form-label">
                    <i class="bi bi-folder"></i> Category
                </label>
                <select asp-for="Category" class="form-select" asp-items="Html.GetEnumSelectList<BuzzIt.Models.Category>()"></select>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <label asp-for="Priority" class="form-label">
                    <i class="bi bi-flag"></i> Priority
                </label>
                <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<BuzzIt.Models.Priority>()"></select>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <label asp-for="DueDate" class="form-label">
                    <i class="bi bi-calendar"></i> Due Date
                </label>
                <input asp-for="DueDate" class="form-control" type="date" />
            </div>
        </div>

        <div class="mb-4">
            <div class="form-check">
                <input asp-for="IsCompleted" class="form-check-input" />
                <label asp-for="IsCompleted" class="form-check-label">
                    <i class="bi bi-check2-circle"></i> Mark as completed
                </label>
            </div>
            @if (Model.CompletedAt.HasValue)
            {
                <p class="text-muted small mb-0 mt-2">
                    <i class="bi bi-clock"></i> Completed at: @Model.CompletedAt.Value.ToString("MMM dd, yyyy h:mm tt")
                </p>
            }
        </div>

        <div class="d-flex flex-wrap gap-3 pt-2">
            <button type="submit" class="btn btn-gradient">
                <i class="bi bi-check-circle-fill"></i> Save Changes
            </button>
            <a asp-controller="Post" asp-action="Index" class="btn btn-outline-gradient">
                <i class="bi bi-arrow-left"></i> Back to Posts
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
