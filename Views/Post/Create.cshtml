@model BuzzIt.Requests.CreatePostRequest

@{
    ViewData["Title"] = "Create Post";
}

<div class="form-container animate-fade-in">
    <h1><i class="bi bi-plus-circle-fill"></i> Create Post</h1>
    
    <form asp-action="Create" method="post">
        <div class="mb-4">
            <label asp-for="Title" class="form-label">
                <i class="bi bi-type"></i> Title
            </label>
            <input asp-for="Title" class="form-control" placeholder="Enter an engaging title..." />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        
        <div class="mb-4">
            <label asp-for="Content" class="form-label">
                <i class="bi bi-chat-text"></i> Content
            </label>
            <textarea asp-for="Content" class="form-control" rows="6" placeholder="Share your thoughts with the world..."></textarea>
            <span asp-validation-for="Content" class="text-danger"></span>
        </div>
        
        <div class="row mb-4">
            <div class="col-md-4">
                <label asp-for="Category" class="form-label">
                    <i class="bi bi-folder"></i> Category
                </label>
                <select asp-for="Category" class="form-control" asp-items="Html.GetEnumSelectList<BuzzIt.Models.Category>()">
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="Priority" class="form-label">
                    <i class="bi bi-flag"></i> Priority
                </label>
                <select asp-for="Priority" class="form-control" asp-items="Html.GetEnumSelectList<BuzzIt.Models.Priority>()">
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="DueDate" class="form-label">
                    <i class="bi bi-calendar"></i> Due Date
                </label>
                <input asp-for="DueDate" class="form-control" type="date" />
            </div>
        </div>
        
        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-gradient btn-gradient-success">
                <i class="bi bi-check-circle-fill"></i> Create Post
            </button>
            <a asp-action="Index" class="btn btn-outline-gradient">
                <i class="bi bi-arrow-left"></i> Back to Posts
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
