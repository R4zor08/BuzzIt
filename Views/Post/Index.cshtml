@model IEnumerable<BuzzIt.Models.Post>

@{
    ViewData["Title"] = "Posts";
    var filterCategory = ViewBag.Category as Category?;
    var filterPriority = ViewBag.Priority as Priority?;
    var filterCompleted = ViewBag.IsCompleted as bool?;
    var searchTerm = ViewBag.SearchTerm as string;
    var hasActiveFilters = !string.IsNullOrWhiteSpace(searchTerm) || filterCategory != null || filterPriority != null || filterCompleted != null;
}

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="page-title mb-1"><i class="bi bi-journal-richtext me-2"></i>Posts</h1>
        <p class="text-muted small mb-0">Search, filter, and manage your own posts.</p>
    </div>
    <a asp-controller="Post" asp-action="Create" class="btn btn-create">
        <i class="bi bi-plus-lg"></i> Create New Post
    </a>
</div>

@if (TempData["ErrorMessage"] is string err)
{
    <div class="alert alert-warning border-0 rounded-3 shadow-sm alert-dismissible fade show" role="alert">
        @err
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="filter-container animate-fade-in mb-4">
    <form asp-controller="Post" asp-action="Index" method="get" class="row g-3 align-items-end">
        <div class="col-12 col-lg-4">
            <label class="form-label small text-muted mb-1">Search</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="searchTerm" value="@searchTerm" class="form-control" placeholder="Search title or content…" aria-label="Search posts" />
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Category</label>
            <select name="category" class="form-select" aria-label="Filter by category">
                @if (filterCategory == null)
                {
                    <option value="" selected>All Categories</option>
                }
                else
                {
                    <option value="">All Categories</option>
                }
                @foreach (BuzzIt.Models.Category cat in Enum.GetValues(typeof(BuzzIt.Models.Category)))
                {
                    if (filterCategory == cat)
                    {
                        <option value="@((int)cat)" selected>@cat</option>
                    }
                    else
                    {
                        <option value="@((int)cat)">@cat</option>
                    }
                }
            </select>
        </div>
        <div class="col-12 col-sm-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Priority</label>
            <select name="priority" class="form-select" aria-label="Filter by priority">
                @if (filterPriority == null)
                {
                    <option value="" selected>All Priorities</option>
                }
                else
                {
                    <option value="">All Priorities</option>
                }
                @foreach (BuzzIt.Models.Priority pri in Enum.GetValues(typeof(BuzzIt.Models.Priority)))
                {
                    if (filterPriority == pri)
                    {
                        <option value="@((int)pri)" selected>@pri</option>
                    }
                    else
                    {
                        <option value="@((int)pri)">@pri</option>
                    }
                }
            </select>
        </div>
        <div class="col-12 col-sm-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Status</label>
            <select name="isCompleted" class="form-select" aria-label="Filter by status">
                @if (filterCompleted == null)
                {
                    <option value="" selected>All Status</option>
                }
                else
                {
                    <option value="">All Status</option>
                }
                @if (filterCompleted == false)
                {
                    <option value="false" selected>Pending</option>
                }
                else
                {
                    <option value="false">Pending</option>
                }
                @if (filterCompleted == true)
                {
                    <option value="true" selected>Completed</option>
                }
                else
                {
                    <option value="true">Completed</option>
                }
            </select>
        </div>
        <div class="col-12 col-lg-2 d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-gradient flex-grow-1">
                <i class="bi bi-funnel"></i> Filter
            </button>
            <a asp-controller="Post" asp-action="Index" class="btn btn-outline-gradient flex-grow-1">
                <i class="bi bi-x-lg"></i> Clear
            </a>
        </div>
    </form>
</div>

@if (Model.Any())
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-xl-4 mb-4 animate-fade-in">
                <div class="post-card h-100 @(item.IsCompleted ? "post-completed" : "") priority-@item.Priority.ToString().ToLower()">
                    @if (item.IsCompleted)
                    {
                        <div class="completed-badge">
                            <i class="bi bi-check-circle-fill"></i> Done
                        </div>
                    }
                    else if (item.DueDate.HasValue && item.DueDate.Value.Date < DateTime.Now.Date)
                    {
                        <div class="overdue-badge">
                            <i class="bi bi-exclamation-circle-fill"></i> Overdue
                        </div>
                    }
                    <div class="post-meta">
                        <span class="category-badge category-@item.Category.ToString().ToLower()">
                            <i class="bi bi-folder"></i> @item.Category
                        </span>
                        <span class="priority-badge priority-@item.Priority.ToString().ToLower()">
                            <i class="bi bi-flag"></i> @item.Priority
                        </span>
                    </div>
                    <h2 class="post-title h5">
                        <i class="bi bi-chat-square-text text-primary"></i>
                        @Html.DisplayFor(modelItem => item.Title)
                    </h2>
                    <p class="post-content">
                        @Html.DisplayFor(modelItem => item.Content)
                    </p>
                    @if (item.DueDate.HasValue)
                    {
                        <p class="due-date @(item.DueDate.Value.Date < DateTime.Now.Date && !item.IsCompleted ? "overdue" : "")">
                            <i class="bi bi-calendar-event"></i> Due: @item.DueDate.Value.ToString("MMM dd, yyyy")
                        </p>
                    }
                    @if (item.IsCompleted && item.CompletedAt.HasValue)
                    {
                        <p class="completed-time">
                            <i class="bi bi-clock"></i> Completed: @item.CompletedAt.Value.ToString("MMM dd, yyyy h:mm tt")
                        </p>
                    }
                    <div class="post-actions">
                        @if (!item.IsCompleted)
                        {
                            <form asp-controller="Post" asp-action="MarkAsDone" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-done">
                                    <i class="bi bi-check2-circle"></i> Done
                                </button>
                            </form>
                        }
                        <a asp-controller="Post" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-edit">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form asp-controller="Post" asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this post? This cannot be undone.');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-delete">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state animate-fade-in">
        <i class="bi bi-inbox"></i>
        <h3>No posts found</h3>
        <p>
            @if (!hasActiveFilters)
            {
                <span>Start by creating your first post.</span>
            }
            else
            {
                <span>No posts match your search or filters. Try adjusting criteria or clear filters.</span>
            }
        </p>
        @if (!hasActiveFilters)
        {
            <a asp-controller="Post" asp-action="Create" class="btn btn-create mt-3">
                <i class="bi bi-plus-lg"></i> Create your first post
            </a>
        }
        else
        {
            <a asp-controller="Post" asp-action="Index" class="btn btn-outline-gradient mt-3">
                <i class="bi bi-arrow-counterclockwise"></i> Clear filters
            </a>
        }
    </div>
}
