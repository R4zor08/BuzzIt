@model IEnumerable<BuzzIt.Models.Post>

@{
    ViewData["Title"] = "Posts";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-postcard-heart"></i> Posts</h1>
    <a asp-action="Create" class="btn btn-create">
        <i class="bi bi-plus-circle-fill"></i> Create New Post
    </a>
</div>

<!-- Search & Filter Section -->
<div class="filter-container animate-fade-in mb-4">
    <form asp-action="Index" method="get" class="row g-3">
        <div class="col-md-3">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" placeholder="Search posts..." />
            </div>
        </div>
        <div class="col-md-2">
            <select name="category" class="form-control">
                <option value="">All Categories</option>
                @foreach (BuzzIt.Models.Category cat in Enum.GetValues(typeof(BuzzIt.Models.Category)))
                {
                    <option value="@((int)cat)" selected="@(ViewBag.Category?.ToString() == cat.ToString())">@cat</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="priority" class="form-control">
                <option value="">All Priorities</option>
                @foreach (BuzzIt.Models.Priority pri in Enum.GetValues(typeof(BuzzIt.Models.Priority)))
                {
                    <option value="@((int)pri)" selected="@(ViewBag.Priority?.ToString() == pri.ToString())">@pri</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="isCompleted" class="form-control">
                <option value="">All Status</option>
                <option value="false" selected="@(ViewBag.IsCompleted == false)">Pending</option>
                <option value="true" selected="@(ViewBag.IsCompleted == true)">Completed</option>
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-gradient me-2">
                <i class="bi bi-funnel"></i> Filter
            </button>
            <a asp-action="Index" class="btn btn-outline-gradient">
                <i class="bi bi-x-circle"></i> Clear
            </a>
        </div>
    </form>
</div>

@if (Model.Any())
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4 animate-fade-in">
                <div class="post-card h-100 @(item.IsCompleted ? "post-completed" : "") priority-@item.Priority.ToString().ToLower()">
                    @if (item.IsCompleted)
                    {
                        <div class="completed-badge">
                            <i class="bi bi-check-circle-fill"></i> Done
                        </div>
                    }
                    else if (item.DueDate.HasValue && item.DueDate.Value.Date < DateTime.Now.Date)
                    {
                        <div class="overdue-badge">
                            <i class="bi bi-exclamation-circle-fill"></i> Overdue
                        </div>
                    }
                    <div class="post-meta">
                        <span class="category-badge category-@item.Category.ToString().ToLower()">
                            <i class="bi bi-folder"></i> @item.Category
                        </span>
                        <span class="priority-badge priority-@item.Priority.ToString().ToLower()">
                            <i class="bi bi-flag"></i> @item.Priority
                        </span>
                    </div>
                    <h5 class="post-title">
                        <i class="bi bi-chat-square-text text-primary"></i>
                        @Html.DisplayFor(modelItem => item.Title)
                    </h5>
                    <p class="post-content">
                        @Html.DisplayFor(modelItem => item.Content)
                    </p>
                    @if (item.DueDate.HasValue)
                    {
                        <p class="due-date @(item.DueDate.Value.Date < DateTime.Now.Date && !item.IsCompleted ? "overdue" : "")">
                            <i class="bi bi-calendar-event"></i> Due: @item.DueDate.Value.ToString("MMM dd, yyyy")
                        </p>
                    }
                    @if (item.IsCompleted && item.CompletedAt.HasValue)
                    {
                        <p class="completed-time">
                            <i class="bi bi-clock"></i> Completed: @item.CompletedAt.Value.ToString("MMM dd, yyyy h:mm tt")
                        </p>
                    }
                    <div class="post-actions">
                        @if (!item.IsCompleted)
                        {
                            <form asp-action="MarkAsDone" asp-route-id="@item.Id" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-done">
                                    <i class="bi bi-check2-circle"></i> Done
                                </button>
                            </form>
                        }
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-edit">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-delete" onclick="return confirm('Are you sure you want to delete this post?')">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state animate-fade-in">
        <i class="bi bi-inbox"></i>
        <h3>No Posts Found</h3>
        <p>@(string.IsNullOrEmpty(ViewBag.SearchTerm) && ViewBag.Category == null && ViewBag.Priority == null && ViewBag.IsCompleted == null ? "Start buzzing! Create your first post and share your thoughts with the world." : "No posts match your search criteria. Try adjusting your filters.")</p>
        @if (string.IsNullOrEmpty(ViewBag.SearchTerm) && ViewBag.Category == null && ViewBag.Priority == null && ViewBag.IsCompleted == null)
        {
            <a asp-action="Create" class="btn btn-create mt-3">
                <i class="bi bi-plus-circle-fill"></i> Create Your First Post
            </a>
        }
        else
        {
            <a asp-action="Index" class="btn btn-outline-gradient mt-3">
                <i class="bi bi-arrow-left"></i> Clear Filters
            </a>
        }
    </div>
}
