@model BuzzIt.DTOs.ReminderDto

@{
    ViewData["Title"] = "Delete reminder";
}

<div class="form-container animate-fade-in" style="max-width: 560px;">
    <h1 class="h4 fw-bold text-danger mb-3"><i class="bi bi-trash me-2"></i>Delete reminder</h1>
    <p class="text-muted mb-4">This will permanently remove the reminder below.</p>

    <div class="rounded-4 bg-light p-4 mb-4">
        <h2 class="h6 fw-bold mb-2">@Model.Title</h2>
        <p class="small text-muted mb-1"><i class="bi bi-clock me-1"></i>@Model.Time.ToString("MMM dd, yyyy h:mm tt")</p>
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="small mb-0">@Model.Description</p>
        }
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-gradient-danger rounded-3 px-4" onclick="return confirm('Delete this reminder permanently?');">Delete</button>
            <a asp-action="Index" class="btn btn-outline-gradient rounded-3 px-4">Cancel</a>
        </div>
    </form>
</div>
