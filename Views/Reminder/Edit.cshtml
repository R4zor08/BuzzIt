@model BuzzIt.Requests.UpdateReminderRequest

@{
    ViewData["Title"] = "Edit Reminder";
}

<div class="form-container animate-fade-in">
    <h1 class="d-flex flex-wrap align-items-center gap-2 mb-4">
        <i class="bi bi-pencil-square text-primary" aria-hidden="true"></i>
        <span>Edit reminder</span>
    </h1>

    <form asp-action="Edit" method="post" class="needs-validation" novalidate>
        <input type="hidden" asp-for="Id" />
        <div class="mb-4">
            <label asp-for="Title" class="form-label">Title</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger small d-block mt-1"></span>
        </div>
        <div class="mb-4">
            <label asp-for="Time" class="form-label">Time</label>
            <input asp-for="Time" class="form-control" type="datetime-local" />
            <span asp-validation-for="Time" class="text-danger small d-block mt-1"></span>
        </div>
        <div class="mb-4">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger small d-block mt-1"></span>
        </div>
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <label asp-for="Category" class="form-label">Category</label>
                <select asp-for="Category" class="form-select" asp-items="Html.GetEnumSelectList<BuzzIt.Models.Category>()"></select>
            </div>
            <div class="col-md-4">
                <label asp-for="Priority" class="form-label">Priority</label>
                <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<BuzzIt.Models.Priority>()"></select>
            </div>
            <div class="col-md-4">
                <label asp-for="DueDate" class="form-label">Due date</label>
                <input asp-for="DueDate" class="form-control" type="date" />
            </div>
        </div>
        <div class="mb-4 form-check">
            <input asp-for="IsCompleted" class="form-check-input" />
            <label asp-for="IsCompleted" class="form-check-label">Completed</label>
        </div>
        <div class="d-flex flex-wrap gap-3">
            <button type="submit" class="btn btn-gradient rounded-3 px-4"><i class="bi bi-check-lg"></i> Save changes</button>
            <a asp-action="Index" class="btn btn-outline-gradient rounded-3 px-4">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
