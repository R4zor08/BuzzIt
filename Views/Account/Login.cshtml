@model BuzzIt.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign in";
    Layout = "_AuthLayout";
}

<div class="auth-panel mx-auto">
    <div class="text-center mb-4">
        <h1 class="h3 fw-bold text-white mb-2">Welcome back</h1>
        <p class="auth-muted small mb-0">Sign in to manage your posts and reminders.</p>
    </div>

    @if (TempData["StatusMessage"] is string msg)
    {
        <div class="alert alert-success border-0 rounded-3 small mb-4" role="alert">@msg</div>
    }

    <form asp-action="Login" asp-controller="Account" method="post" novalidate class="auth-form">
        <input type="hidden" asp-for="ReturnUrl" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 small py-2"></div>

        <div class="mb-3">
            <label asp-for="Username" class="form-label auth-muted small fw-semibold"></label>
            <input asp-for="Username" class="form-control form-control-lg auth-input" autocomplete="username" autofocus placeholder="Username" />
            <span asp-validation-for="Username" class="text-warning small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label text-white-50 small fw-semibold"></label>
            <input asp-for="Password" class="form-control form-control-lg auth-input" autocomplete="current-password" placeholder="Password" />
            <span asp-validation-for="Password" class="text-warning small"></span>
        </div>
        <div class="mb-4 form-check">
            <input asp-for="RememberMe" class="form-check-input auth-check" />
            <label asp-for="RememberMe" class="form-check-label auth-muted small"></label>
        </div>
        <button type="submit" class="btn btn-auth-primary btn-lg w-100 rounded-3 fw-semibold">Sign in</button>
    </form>

    <p class="text-center auth-muted small mt-4 mb-0">
        New here?
        <a asp-action="Register" asp-controller="Account" class="link-light fw-semibold text-decoration-none">Create an account</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
