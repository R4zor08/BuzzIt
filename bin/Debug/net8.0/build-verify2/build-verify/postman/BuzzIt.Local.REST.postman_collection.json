    {
      "name": "Reminders - Get Existing",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/reminders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "reminders"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const reminders = pm.response.json();",
              "pm.test('Response is an array', function () {",
              "  pm.expect(Array.isArray(reminders)).to.eql(true);",
              "});",
              "if (reminders.length === 0) {",
              "  pm.environment.unset('reminderId');",
              "  postman.setNextRequest(null);",
              "  pm.test('No reminders in DB so reminder-specific tests are skipped', function () {",
              "    pm.expect(reminders.length).to.eql(0);",
              "  });",
              "} else {",
              "  const first = reminders[0];",
              "  pm.environment.set('reminderId', String(first.id));",
              "  pm.test('At least one existing reminder is present', function () {",
              "    pm.expect(reminders.length).to.be.above(0);",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
