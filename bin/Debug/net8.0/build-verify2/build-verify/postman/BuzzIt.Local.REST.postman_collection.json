{
  "info": {
    "_postman_id": "7f4ed14a-5f56-4685-a04d-6f61831778f5",
    "name": "BuzzIt Local REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Local REST API tests using only existing database records."
  },
  "item": [
    {
      "name": "Posts - Get Existing",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/posts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "posts"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const posts = pm.response.json();",
              "pm.test('Response is an array', function () {",
              "  pm.expect(Array.isArray(posts)).to.eql(true);",
              "});",
              "pm.test('At least one existing post is present', function () {",
              "  pm.expect(posts.length).to.be.above(0);",
              "});",
              "const first = posts[0];",
              "pm.environment.set('postId', String(first.id));",
              "pm.environment.set('postTitle', first.title || '');",
              "pm.environment.set('postContent', first.content || '');",
              "pm.environment.set('postCategory', String(first.category ?? 0));",
              "pm.environment.set('postPriority', String(first.priority ?? 1));",
              "pm.environment.set('postDueDateJson', first.dueDate ? JSON.stringify(first.dueDate) : 'null');"
            ]
          }
        }
      ]
    },
    {
      "name": "Posts - Get By Existing ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/posts/{{postId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "posts",
            "{{postId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const post = pm.response.json();",
              "pm.test('ID matches selected existing post', function () {",
              "  pm.expect(String(post.id)).to.eql(pm.environment.get('postId'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Posts - Update Existing",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{postTitle}}\",\n  \"content\": \"{{postContent}}\",\n  \"category\": {{postCategory}},\n  \"priority\": {{postPriority}},\n  \"dueDate\": {{postDueDateJson}},\n  \"isCompleted\": false,\n  \"completedAt\": null\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/posts/{{postId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "posts",
            "{{postId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
